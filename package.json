{
  "name": "playwright-smart-inspector",
  "version": "1.1.0",
  "description": "Playwright library with interactive inspector and self-healing locators",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "prepublishOnly": "tsc -p tsconfig.build.json",

    "inspect": "playwright test tests/inspect.spec.ts",
    "inspect:url": "playwright test tests/inspect.spec.ts",

    "test:manual": "playwright test tests/manual-inspector.spec.ts",
    "test:manual:demo": "playwright test tests/manual-inspector.spec.ts --grep \"Demo\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Evgeniy955/catch_locator"
  },
  "keywords": [
    "playwright",
    "testing",
    "inspector",
    "locator",
    "self-healing",
    "test-automation"
  ],
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3"
  }
}
